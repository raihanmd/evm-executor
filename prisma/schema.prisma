generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Pool {
  id             String @id @default(cuid())
  chainId        Int
  address        String
  token0Address  String
  token1Address  String
  token0Symbol   String
  token1Symbol   String
  token0Decimals Int
  token1Decimals Int
  feeTier        Int

  positions Position[]
  createdAt BigInt

  @@unique([chainId, address])
}

model Position {
  id      String @id @default(cuid())
  chainId Int
  tokenId String

  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])

  status PositionStatus @default(ACTIVE)

  tickLower    Int
  tickUpper    Int
  rangePercent Int
  tickAtMint   Int

  deployAmountUsdt String
  amount0Deposited String
  amount1Deposited String
  liquidity        String

  swapAmountIn        String?
  swapAmountOutMin    String?
  swapAmountOutActual String?

  mintTxHash      String
  mintBlockNumber BigInt
  mintedAt        BigInt

  lastCheckedAt BigInt?
  lastInRangeAt BigInt?
  oorSince      BigInt?

  exitReason           ExitReason?
  closeTxHash          String?
  closeBlockNumber     BigInt?
  closedAt             BigInt?
  amount0Withdrawn     String?
  amount1Withdrawn     String?
  feesCollected0       String?
  feesCollected1       String?
  finalSweepAmountUsdt String?
  pnlUsdt              String?
  pnlPercent           String?
  uncollectedFeeUsd    String?
  peakPnlPct           String?
  lastToken0Amount     String?
  lastToken1Amount     String?

  previousPositionId String?   @unique
  previousPosition   Position? @relation("Lineage", fields: [previousPositionId], references: [id])
  nextPosition       Position? @relation("Lineage")
  rootPositionId     String?

  configSnapshot  Json
  recipientWallet String

  checks PositionCheck[]
  txLogs TxLog[]

  createdAt BigInt
  updatedAt BigInt

  @@unique([chainId, tokenId])
}

model PositionCheck {
  id         String   @id @default(cuid())
  positionId String
  position   Position @relation(fields: [positionId], references: [id])

  checkedAt   BigInt
  currentTick Int
  inRange     Boolean

  currentValueUsdt String
  drawdownPct      String

  poolTvl       String
  poolVolume24h String
  poolFeesApr   String

  decision       CheckDecision
  decisionReason String
}

model TxLog {
  id         String    @id @default(cuid())
  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  txHash String   @unique
  action TxAction
  status TxStatus

  blockNumber BigInt?
  gasUsed     BigInt?
  gasPriceWei String?
  gasCostBnb  String?
  gasCostUsd  String?

  createdAt BigInt
}

enum PositionStatus {
  ACTIVE
  OUT_OF_RANGE
  REBALANCING
  CLOSED
  EXITED
  FAILED
}

enum ExitReason {
  OOR_TIMEOUT
  DRAWDOWN_STOP
  RUG_TVL_DROP
  LOW_VOLUME
  REBALANCED
  MANUAL
}

enum CheckDecision {
  HOLD
  REBALANCE
  EXIT
  NONE
}

enum TxAction {
  APPROVE
  SWAP
  MINT
  DECREASE_LIQUIDITY
  COLLECT
  SWEEP
}

enum TxStatus {
  SUCCESS
  FAILED
  REVERTED
}
